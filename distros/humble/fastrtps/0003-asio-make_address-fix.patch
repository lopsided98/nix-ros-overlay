diff --git a/src/cpp/rtps/transport/TCPAcceptor.cpp b/src/cpp/rtps/transport/TCPAcceptor.cpp
index 951b25648..1ad95a283 100644
--- a/src/cpp/rtps/transport/TCPAcceptor.cpp
+++ b/src/cpp/rtps/transport/TCPAcceptor.cpp
@@ -39,13 +39,13 @@ TCPAcceptor::TCPAcceptor(
         asio::io_context& io_context,
         const std::string& interface,
         const Locator& locator)
-    : acceptor_(io_context, asio::ip::tcp::endpoint(asio::ip::address_v4::from_string(interface),
+    : acceptor_(io_context, asio::ip::tcp::endpoint(asio::ip::make_address_v4(interface),
             IPLocator::getPhysicalPort(locator)))
     , locator_(locator)
     , io_context_(&io_context)
 {
     locator_.port = acceptor_.local_endpoint().port();
