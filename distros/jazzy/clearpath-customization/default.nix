  version = "2.9.7-r1";

  src = fetchurl {
    url = "https://github.com/clearpath-gbp/clearpath_common-release/archive/release/jazzy/clearpath_customization/2.9.7-1.tar.gz";
    name = "2.9.7-1.tar.gz";
    sha256 = "c3872eaeadcdd12e6a181d6f03185901fedc8391b64f102997512215497074da";
